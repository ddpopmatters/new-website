# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=       # from sanity.io/manage — create project first
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=               # Viewer token from sanity.io/manage > API > Tokens
SANITY_REVALIDATE_SECRET=            # random string for ISR webhook auth (openssl rand -hex 32)

# Used by Sanity Studio (visual editing)
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3000/studio
